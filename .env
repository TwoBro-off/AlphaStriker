# Clés d'API et configuration du bot pour le backend
# Ne commitez JAMAIS vos vraies clés dans un dépôt public.
# Ce fichier doit être ignoré par Git (.gitignore).

# --- Wallet ---
# Clé privée du portefeuille en format Base58. OBLIGATOIRE pour le bot.
PRIVATE_KEY="VOTRE_CLE_PRIVEE_SOLANA_EN_BASE58"
# Adresse publique du portefeuille. Utile pour l'affichage ou certaines vérifications.
# Peut être dérivée de la clé privée, mais la spécifier ici est plus simple.
WALLET_ADDRESS="VOTRE_ADRESSE_PUBLIQUE_SOLANA"

# --- Connexions API ---
# URL du noeud RPC Solana.
RPC_URL="https://api.mainnet-beta.solana.com"
# Clé API Helius. OBLIGATOIRE pour certaines fonctionnalités (ex: log scanner).
HELIUS_API_KEY="VOTRE_CLE_API_HELIUS"
# Clé API Gemini (Google AI). OPTIONNELLE, utilisée par l'optimiseur IA.
GEMINI_API_KEY="VOTRE_CLE_API_GEMINI_OPTIONNELLE"

# --- Paramètres de Trading ---
# Montant en SOL à utiliser pour chaque achat.
BUY_AMOUNT_SOL=0.01
# Multiplicateur de profit pour la vente (ex: 2.0 pour vendre à 2x le prix d'achat).
SELL_MULTIPLIER=2.0
# Pourcentage de stop suiveur (ex: 0.15 pour vendre si le prix baisse de 15% par rapport au max).
TRAILING_STOP_PERCENT=0.15
# Pourcentage du capital total à allouer par trade (si applicable, sinon BUY_AMOUNT_SOL est prioritaire).
TRADE_AMOUNT_SOL_PERCENT=0.1
# Durée maximale de maintien d'une position en secondes.
MAX_TRADE_DURATION_SECS=7200
# Liste de Pubkeys de créateurs de confiance, séparées par des virgules.
TRUSTED_CREATORS=""

# --- Mode de fonctionnement ---
# "DEMO" pour le mode simulation, "REAL" pour le trading avec de vrais fonds.
RUN_MODE="DEMO"
